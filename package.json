{
  "name": "@zbkit/tools",
  "type": "module",
  "version": "0.1.0-beta.1",
  "description": "A starter for creating a TypeScript package.",
  "author": "Bill Zhang <zbjumper@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/zbjumper/npm-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zbjumper/npm-tools.git"
  },
  "bugs": {
    "url": "https://github.com/zbjumper/npm-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "pub": "bumpp --commit --tag && npm_tag=$(node -e \"const v=require('./package.json').version;const m=v.match(/-(alpha|beta|rc)\\./);console.log(m?m[1]:'latest')\") && pnpm publish --access public --tag $npm_tag",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=7"
  }
}
